entrypoint = "README.md"
modules = ["nodejs-22", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "vm"
build = ["node", "scripts/build.js"]
run = ["tsx", "server/index.ts"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 23636
externalPort = 3002

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["revenuecat:1.0.0", "javascript_openai_ai_integrations:2.0.0", "stripe:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start dev servers"

[[workflows.workflow]]
name = "Start dev servers"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'fuser -k 5000/tcp 8081/tcp 2>/dev/null; sleep 1; trap \"kill 0\" EXIT SIGTERM SIGINT; (EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost) & (NODE_ENV=development tsx server/index.ts); wait'"
waitForPort = 5000

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_sMuoeWyOuPayWQDjVijMcWUmRWH"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_AnbquvdHmKFyJlQHpDBxmIEiftn"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_IlSnajmkDeyeAArlVioZeqSPxZT"
REVENUECAT_PROJECT_ID = "proj56c00538"
REVENUECAT_TEST_STORE_APP_ID = "app4f9782154a"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appb4010de6dd"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app3066c5f760"
